{
  "expo": {
    "name": "SnapToStudy",
    "slug": "snaptostudy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "snaptostudy",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070b1a"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "SnapToStudy uses your camera to scan homework problems and get step-by-step solutions.",
        "NSPhotoLibraryUsageDescription": "SnapToStudy needs access to your photos so you can scan saved homework images."
      },
      "bundleIdentifier": "com.snaptostudy.app"
    },
    "android": {
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ],
      "package": "com.snaptostudy.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "SnapToStudy needs access to your photos so you can scan saved homework images.",
          "cameraPermission": "SnapToStudy uses your camera to scan homework problems and get step-by-step solutions."
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
